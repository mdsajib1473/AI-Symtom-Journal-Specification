# Copy this file to .env and fill in real values. Never commit .env.

# Django secret key — generate a unique value per environment, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Debug mode: True for local development, False in production.
DEBUG=True

# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# If the password contains special characters (# @ / : etc.), percent-encode them.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/symptom_journal_db

# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
